# ============================================
# GreenOps Autonomous - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=greenops

# Backend API
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Kubernetes
K8S_NAMESPACE=greenops
WORKLOAD_DEPLOYMENT_NAME=green-workload
MIN_REPLICAS=0
MAX_REPLICAS=5

# Autoscaler Settings
SCALE_UP_CPU_THRESHOLD=65
SCALE_DOWN_CPU_THRESHOLD=25
TARGET_RPS_PER_POD=20
IDLE_SCALE_TO_ZERO_SECONDS=60
SCALE_UP_COOLDOWN_SECONDS=10
SCALE_DOWN_COOLDOWN_SECONDS=60

# Energy / Carbon / Cost
P_IDLE_WATTS=35
P_MAX_WATTS=90
CARBON_FACTOR_KG_PER_KWH=0.708
ELECTRICITY_COST_PER_KWH=8

# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Gateway
GATEWAY_PORT=5001
WORKLOAD_URL=http://green-workload-service:5000

# Frontend
VITE_BACKEND_URL=http://localhost:8000
VITE_GATEWAY_URL=http://localhost:5001
